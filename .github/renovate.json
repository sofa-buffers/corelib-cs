{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions bumps into one PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Group the NuGet test/coverage packages (xunit, Microsoft.NET.Test.Sdk, coverlet); the runtime library has no PackageReferences.",
      "matchManagers": ["nuget"],
      "groupName": "nuget test dependencies"
    },
    {
      "description": "Devcontainer base image (.devcontainer/Dockerfile -> mcr.microsoft.com/dotnet/sdk).",
      "matchManagers": ["dockerfile"],
      "groupName": "devcontainer image"
    }
  ]
}
