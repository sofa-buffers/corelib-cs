{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": ["src/SofaBuffers/SofaBuffers.csproj"]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "memberLayout": "samePage",
      "namespaceLayout": "nested",
      "enumSortOrder": "declaringOrder"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["*.md", "toc.yml"]
      }
    ],
    "resource": [
      {
        "src": "..",
        "files": ["assets/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "SofaBuffers C#",
      "_appTitle": "SofaBuffers C#",
      "_appFooter": "SofaBuffers C# &middot; MIT License",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/sofa-buffers/corelib-cs",
        "branch": "main"
      }
    }
  }
}
